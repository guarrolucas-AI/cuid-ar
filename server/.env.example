# Base de datos (Supabase o cualquier PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/cuid_ar?sslmode=require"

# JWT — cambiá esto por una string larga y aleatoria
JWT_SECRET="reemplaza-con-una-clave-secreta-larga"

# Mercado Pago — obtenés el Access Token en developers.mercadopago.com
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"

# Servidor
PORT=4000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
